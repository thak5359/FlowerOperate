using System.Collections.Generic;
using UnityEngine;
using UnityEngine.AddressableAssets; // ïżœß°ïżœ
using UnityEngine.ResourceManagement.AsyncOperations; // ïżœß°ïżœ


public class ObjectPool : MonoBehaviour
{
    public static ObjectPool Instance;

    [SerializeField]
    private AssetReference prefabReference; // GameObject ïżœïżœïżœ AssetReference ïżœïżœïżœ

    private GameObject loadedPrefab; // ïżœÎ”ïżœïżœ ïżœïżœïżœïżœïżœïżœ ïżœïżœïżœïżœïżœ
    private Queue<ItemDataContainer> poolingObjectQueue = new Queue<ItemDataContainer>();

    async void Awake() // asyncïżœïżœ ïżœïżœïżœïżœïżœÏżïżœ ïżœÎ”ïżœïżœïżœ ïżœïżœÙžïżœïżœÏŽïżœ.
    {
        Instance = this;

        // 2. ïżœïżœć·čïżœïżœïżœïżœïżœïżœ ïżœïżœïżœïżœïżœïżœ ïżœÎ”ïżœ ïżœïżœïżœïżœ
        AsyncOperationHandle<GameObject> handle = Addressables.LoadAssetAsync<GameObject>(prefabReference);
        await handle.Task;

        if (handle.Status == AsyncOperationStatus.Succeeded)
        {
            loadedPrefab = handle.Result;
            Initialize(10);
