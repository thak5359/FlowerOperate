--- !u!114 &5560874622980526614
MonoBehaviour:
  m_ObjectHideFlags: 0
  m_CorrespondingSourceObject: {fileID: 0}
  m_PrefabInstance: {fileID: 0}
  m_PrefabAsset: {fileID: 0}
  m_GameObject: {fileID: 6554923606033240867}
  m_Enabled: 1
  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: 5f7201a12d95ffc409449d95f23cf332, type: 3}
  m_Name: 
  m_EditorClassIdentifier: 
  m_Material: {fileID: 0}
  m_Color: {r: 1, g: 1, b: 1, a: 1}
  m_RaycastTarget: 1
  m_RaycastPadding: {x: 0, y: 0, z: 0, w: 0}
  m_Maskable: 1
  m_OnCullStateChanged:
    m_PersistentCalls:
      m_Calls: []
  m_FontData:
    m_Font: {fileID: 12800000, guid: 9541896479cb5614cbaa4a459f28f994, type: 3}
    m_FontSize: 30
    m_FontStyle: 0
    m_BestFit: 0
    m_MinSize: 0
    m_MaxSize: 50
    m_Alignment: 0
    m_AlignByGeometry: 0
    m_RichText: 1
    m_HorizontalOverflow: 0
    m_VerticalOverflow: 1
    m_LineSpacing: 1
  m_Text: "<b>\uC57C\uC2A4\uB2E4 \uC0AC\uD1A0\uBBF8</b>\r\n\uD0C0\uCF00\uB2E4 \uB2D8.
    \uC624\uB298\uC740 \uC81C \uBD80\uD0C1\uC744 \uB4E4\uC5B4\uC8FC\uB294 \uB0A0\uC774\uC8E0?\r\n\r\n\uC65C
    \uADF8\uAC78 \uC800\uB807\uAC8C \uC2AC\uD508 \uD45C\uC815\uC73C\uB85C \uB9D0\uD558\uB294
    \uAC78\uAE4C.\r\n\n<b>\uB2F9\uC2E0</b>\n\uC5B4, \uC751. \uADF8\uB798\uC11C\xB7\xB7\xB7\xB7\xB7\xB7.\r\n\r\n'\uB370\uC774\uD2B8\uD55C
    \uAC70\uC796\uC544?'\uB77C\uB294 \uB9D0\uC740 \uB098\uC624\uC9C0 \uC54A\uC558\uB2E4.\r\n\uADF8\uB140\uB294
    \uB098\uC640 \uB370\uC774\uD2B8\uB97C \uD558\uACE0 \uC2F6\uB2E4\uACE0 \uB9D0\uD55C
    \uC801\uC774 \uC5C6\uC73C\uB2C8\uAE4C.\r\n\uC7A0\uAE50, \uADF8\uB7EC\uBA74 \uADF8\uB140\uC758
    \uBD80\uD0C1\uC740-\r\n\r\n<b>\uC57C\uC2A4\uB2E4 \uC0AC\uD1A0\uBBF8</b>\r\n\uADF8\uB7EC\uBA74
    \uD0C0\uCF00\uB2E4 \uB2D8.\r\n\uADF8\uB54C\uC758 \uC57D\uC18D\xB7\xB7\xB7\xB7\xB7\xB7,
    \uC78A\uC5B4 \uC8FC\uC2ED\uC2DC\uC694.\r\n\r\n\xB7\xB7\xB7\xB7\xB7\xB7.\r\n\uADF8
    \uB9D0\uC5D0 \uB2F4\uAE34 \uB73B\uC744 \uC774\uD574\uD558\uB294\uB370 \uC2DC\uAC04\uC774
    \uAC78\uB838\uB2E4.\r\n\uADF8\uB9AC\uACE0 \uADF8 \uC758\uBBF8\uB97C \uAE68\uB2EC\uC558\uC744
    \uB54C, \uB0B4 \uC785\uC774 \uC81C\uBA4B\uB300\uB85C \uC6C0\uC9C1\uC600\uB2E4.\r\n\r\n<b>\uB2F9\uC2E0</b>\r\n\uC790,
    \uC790, \uC790, \uC7A0\uAE50, \uC0AC\uD1A0\uBBF8. \uADF8, \uADF8\uAC8C, \uC5B4
    \uADF8\uB7EC\uB2C8\uAE4C, \uBB50?\r\n\uC544\uB2C8, \uC5B4, \uBB50\uB77C\uACE0?
    \uC790, \uC7A0\uAE50\uB9CC, \uC9C4\uC9DC? \uC5B4? \uC7A0\uAE50\uB9CC, \uC9C0\uAE08.
    \uC5B4, \uC65C?\r\n\uADF8\uAC8C \uBD80\uD0C1\uC774\uC57C? \uC544, \uC544\uB2C8,
    \uC9C4\uC9DC?\r\n\r\n<b>\uC57C\uC2A4\uB2E4 \uC0AC\uD1A0\uBBF8</b>\r\n\uC9C0\uAE08\uC740
    \uC800 \uB9D0\uACE0\uB3C4 \uB2F9\uC2E0\uC758 \uACC1\uC5D0 \uC788\uC5B4 \uC8FC\uB294
    \uC0AC\uB78C\uB4E4\uC774 \uB9CE\uC774 \uC788\uC9C0\uC54A\uC2B5\uB2C8\uAE4C?\r\n\uADF8
    \uC57D\uC18D, \uC774\uC81C \uC9C0\uD0A4\uC9C0 \uC54A\uC544\uB3C4 \uB2F9\uC2E0\uC740
    \uAD1C\uCC2E\uACA0\uC9C0\uC694.\r\n\r\n<b>\uB2F9\uC2E0</b>\r\n\uC0AC, \uC0AC\uD1A0\uBBF8,
    \uAC11\uC790\uAE30 \uBB34\uC2A8 \uB9D0\uC774\uC57C?\r\n\r\n<b>\uC57C\uC2A4\uB2E4
    \uC0AC\uD1A0\uBBF8</b>\r\n\uAC11\uC790\uAE30\uAC00 \uC544\uB2D9\uB2C8\uB2E4.\r\n\r\n<b>\uC57C\uC2A4\uB2E4
    \uC0AC\uD1A0\uBBF8</b>\r\n\uC54C\uACE0 \uACC4\uC168\uC9C0 \uC54A\uC2B5\uB2C8\uAE4C.\r\n\r\n<b>\uC57C\uC2A4\uB2E4
    \uC0AC\uD1A0\uBBF8</b>\r\n\uC804 \uC774\uC81C \uACC1\uC5D0 \uC5C6\uC5B4\uB3C4
    \uB41C\uB2E4\uB294\uAC70.\r\n\r\n<b>\uC57C\uC2A4\uB2E4 \uC0AC\uD1A0\uBBF8</b>\r\n\uADF8\uB3D9\uC548\xB7\xB7\xB7\xB7\xB7\xB7
    \uB9CE\uC774 \uACE0\uBBFC\uD588\uC2B5\uB2C8\uB2E4.\r\n\r\n\uD0C0\uCF00\uB2E4
    \uB2D8\uACFC \uB9AC\uC624 \uB2D8\uC774 \uADF8\uB7F0\uAC78 \uB2F9\uC5F0\uD558\uB2E4\uACE0
    \uC0DD\uAC01\uD574\uB3C4 \uC800\uB294 \uC544\uB2D9\uB2C8\uB2E4.\r\n\r\n<b>\uC57C\uC2A4\uB2E4
    \uC0AC\uD1A0\uBBF8</b>\r\n\uD0C0\uCF00\uB2E4 \uB2D8\uC5D0\uAC8C\uB3C4 \uB9D0\uD588\uC2B5\uB2C8\uB2E4.\r\n\r\n\uC800\uB3C4
    \uC2AC\uC2AC \uD55C\uACC4\uB124\uC694.\r\n\r\n<b>\uC57C\uC2A4\uB2E4 \uC0AC\uD1A0\uBBF8</b>\r\n\uC5B8\uC9C8\uB3C4
    \uC8FC\uC5C8\uAD6C\uC694.\r\n\r\n\uC0AC\uD1A0\uBBF8\uAC00 \uC0B4\uC9DD \uC544\uB7AB\uC785\uC220\uC744
    \uC539\uC5C8\uB2E4.\r\n\r\n<b>\uC57C\uC2A4\uB2E4 \uC0AC\uD1A0\uBBF8</b>\r\n\uC54C\uC544\uC92C\uC73C\uBA74
    \uD588\uC2B5\uB2C8\uB2E4.\r\n\r\n\uD654\uB97C \uCC38\uACE0 \uC788\uB294\uAC8C
    \uC544\uB2C8\uB77C \uC815\uB9D0 \uD654 \uC790\uCCB4\uAC00 \uC548 \uB09C \uAC83
    \uAC19\uB2E4.\r\n\r\n<b>\uC57C\uC2A4\uB2E4 \uC0AC\uD1A0\uBBF8</b>\r\n\uB108\uBB34
    \uAD34\uB85C\uC6CC\uC11C\xB7\xB7\xB7\xB7\xB7\xB7. \uC774\uC0C1\uD55C \uC0DD\uAC01\uB3C4
    \uB4E4\uC5C8\uC2B5\uB2C8\uB2E4.\r\n\r\n\uC804 \uD0C0\uCF00\uB2E4 \uB2D8\uC774
    \uCC28\uB77C\uB9AC \uC5EC\uC790\uB77C\uBA74 \uC88B\uC744 \uAC70 \uAC19\uC2B5\uB2C8\uB2E4.\r\n\r\n<b>\uC57C\uC2A4\uB2E4
    \uC0AC\uD1A0\uBBF8</b>\r\n\uADF8\uB7F0\uB370\xB7\xB7\xB7\xB7\xB7\xB7 \uD0C0\uCF00\uB2E4
    \uB2D8\uC740 \uBAA8\uB974\uB294 \uCC99\uD558\uB354\uAD70\uC694. \uC804\uBD80
    \uC54C\uACE0 \uC788\uC5C8\uC73C\uBA74\uC11C.\r\n\r\n\uD790\uB09C \uAC19\uC740
    \uB9D0\uC5D0, \uB098\uB294 \uC815\uC2E0\uC774 \uB4E4\uC5C8\uB2E4.\r\n\r\n\uADF8\uB798.
    \uC54C\uACE0 \uC788\uC5C8\uB2E4. \uC694 \uC77C\uC8FC\uC77C\uAC04 \uC0AC\uD1A0\uBBF8\uC758
    \uD3C9\uC18C\uC640 \uD0DC\uB3C4\uAC00 \uB2E4\uB974\uB2E4\uB294 \uAC83\uC744.\r\n\uD558\uC9C0\uB9CC
    \uC2E0\uACBD\uC4F0\uC9C0 \uC54A\uC558\uB2E4. \uAC04\uACFC\uD588\uB2E4. \uC0DD\uAC01\uD558\uC9C0
    \uC54A\uC558\uB2E4. '\uBCF4\uB958'\uD558\uB294\uB370 \uC548\uC8FC\uD588\uB2E4.\r\n\r\n\uC0AC\uD1A0\uBBF8\uAC00
    \uB098\uB97C \uBC84\uB9AC\uB294 \uC77C\uC740 \uC5C6\uC744 \uAC70\uB77C\uACE0
    \uBBFF\uACE0 \uC788\uC5C8\uB2E4.\r\n\r\n\uC57D\uC18D.\r\n\uADF8 \uC57D\uC18D
    \uD558\uB098\uC5D0 \uAE30\uB304 \uCC44 \uC548\uC8FC\uD588\uB2E4.\r\n\r\n\r\n<b>\uC57C\uC2A4\uB2E4
    \uC0AC\uD1A0\uBBF8</b>\r\n\uADF8\uB7EC\uB2C8\uAE4C.\r\n\r\n\uADF8\uB7EC\uB2C8\uAE4C
    \uC9C0\uAE08\uC758 \uB098\uB294 \uADF8 \uB300\uAC00\uB97C \uBC1B\uB294 \uAC70\uB2E4.\r\n\r\n<b>\uC57C\uC2A4\uB2E4
    \uC0AC\uD1A0\uBBF8</b>\r\n\uC81C\uAC00 \uACB0\uC2EC\uD588\uC2B5\uB2C8\uB2E4\r\n\r\n\uC2A4\uC2A4\uB85C\uC5D0
    \uB300\uD55C \uC8C4\uC545\uAC10\uC5D0 \uC9D3\uB20C\uB824\uC11C\r\n\r\n<b>\uC57C\uC2A4\uB2E4
    \uC0AC\uD1A0\uBBF8</b>\r\n\uD0C0\uCF00\uB2E4 \uB2D8.\r\n\r\n\uB098\uB294 \uC544\uBB34\uB7F0
    \uB9D0\uB3C4 \uD560 \uC218 \uC5C6\uC5C8\uB2E4.\r\n\r\n<b>\uC57C\uC2A4\uB2E4 \uC0AC\uD1A0\uBBF8</b>\r\n\uC8C4\uC1A1\uD569\uB2C8\uB2E4.\r\n\r\n\uC0AC\uD1A0\uBBF8\uAC00
    \uB0B4\uAC8C \uB2E4\uAC00\uC654\uB2E4. \uB0B4 \uB450 \uC5B4\uAE68\uB97C \uC0B4\uD3EC\uC2DC
    \uC7A1\uACE0 \uACE0\uAC1C\uB97C \uAE30\uC6B8\uC778\uB2E4.\r\n\uC810\uC810 \uB0B4\uC640
    \uC0AC\uD1A0\uBBF8 \uC0AC\uC774\uAC00 \uAC00\uAE4C\uC6CC\uC84C\uACE0.\r\n\r\n\uC0AC\uD1A0\uBBF8\uAC00
    \uB124\uAC8C \uD0A4\uC2A4\uD588\uB2E4.\r\n\r\n\uADF8\uC800 \uC785\uC220\uB9CC\uC774
    \uB2FF\uB294, \uC5B4\uB9B0\uC544\uC774 \uAC19\uC740 \uAC00\uBCBC\uC6B4 \uC785\uB9DE\uCDA4.
    \uD558\uC9C0\uB9CC \uADF8\uB7FC\uC5D0\uB3C4 \uADF8 \uC785\uC220\uC5D0\uC11C \uB290\uAEF4\uC9C0\uB294
    \uC5F4\uAE30\uB294 \uB728\uAC70\uC6E0\uACE0,\r\n\uB0B4 \uC2EC\uCC3D\uC744 \uACE0\uB3D9\uCE58\uAC8C
    \uB9CC\uB4E4\uC5C8\uB2E4.\r\n\r\n\uADF8\uAC83\uC740 \uAE30\uC068\uACFC \uD589\uBCF5,
    \uADF8\uB9AC\uACE0 \uD765\uBD84\xB7\xB7\xB7\xB7\xB7\xB7\uACFC\uB294 \uBA85\uBC31\uD788
    \uB2E4\uB978 \uC774\uC720\uC600\uB2E4.\r\n\r\n\uB450\uB824\uC6C0.\r\n\r\n\uB05D\uB9FA\uC74C\uC758
    \uC758\uC2DD\uC5D0 \uB300\uD55C \uACF5\uD3EC.\r\n\r\n<b>\uC57C\uC2A4\uB2E4 \uC0AC\uD1A0\uBBF8</b>\r\n\uD0C0\uCF00\uB2E4
    \uB2D8.\r\n\r\n\uBB34\uC2A8 \uB9D0\uC774\uB4E0 \uD574\uC57C\uD55C\uB2E4. \uADF8\uAC8C
    \uBB34\uC2A8 \uB9D0\uC774\uB4E0. \uC0AC\uD1A0\uBBF8\uAC00 \uB354 \uC774\uC0C1
    \uB9D0\uD558\uC9C0 \uBABB\uD558-\r\n\r\n<b>\uC57C\uC2A4\uB2E4 \uC0AC\uD1A0\uBBF8</b>\r\n\uC5F0\uBAA8\uD558\uACE0
    \uC788\uC5C8\uC2B5\uB2C8\uB2E4.\r\n\r\n\uB0B4 \uC2EC\uC7A5\uC774 \uBA48\uCDB0\uBC84\uB838\uB2E4.\r\n"
