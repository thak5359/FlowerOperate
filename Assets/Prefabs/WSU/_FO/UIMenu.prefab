--- !u!114 &753133259642362902
MonoBehaviour:
  m_ObjectHideFlags: 0
  m_CorrespondingSourceObject: {fileID: 0}
  m_PrefabInstance: {fileID: 0}
  m_PrefabAsset: {fileID: 0}
  m_GameObject: {fileID: 8087618876336220865}
  m_Enabled: 1
  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: b011f4ae99926e2428f34b629f481e9d, type: 3}
  m_Name: 
  m_EditorClassIdentifier: 
  previewText: {fileID: 2480803794573937245}
  firstMeetLines:
  - "\uC548\uB155! \uB098\uB294 \uC5EC\uAE30\uC5D0\uC11C \uB9D0\uD558\uAE30 \uC544\uB974\uBC14\uC774\uD2B8\uB97C
    \uD558\uACE0 \uC788\uB294 \uD0C0\uCE74\uD558\uC2DC \uC720\uC6B0\uB098\uC57C~.
    \uC624\uB298 \uBC25\uC740 \uBA39\uC5C8\uC5B4?"
  - "\uCC44\uD305 \uC124\uC815~. \uCC44\uD305 \uC124\uC815~. \uCC44\uD305 \uC124\uC815\uC740
    \uC5EC\uAE30\uC11C \uB2F4\uB2F9\uD558\uACE0 \uC788\uB2F5\uB2C8\uB2E4~. \uC544!
    \uC5B4\uC11C \uC640~\u266A"
  - "\uC124\uC815\uCC3D\uC5D0 \uC628 \uAC78 \uD658\uC601\uD574~! \uB300\uD654 \uC18D\uB3C4\uB97C
    \uBC14\uAFB8\uB7EC \uC628\uAC70\uC57C? \uADF8\uAC83\uB3C4 \uC544\uB2C8\uBA74
    \uD654\uBA74 \uD06C\uAE30\uB97C \uC870\uC808\uD558\uB824\uACE0? \uADF8\uAC83\uB3C4
    \uC544\uB2C8\uBA74\xB7\xB7\xB7\xB7\xB7\xB7 \uB098 \uBCF4\uACE0 \uC2F6\uC5C8\uC5B4?"
  - "\uC548\uB155\uD558\uC138\uC694! \uB098\uB294 \uD504\uB85C\uC81D\uD2B8JR\uC758
    \uB9C8\uC2A4\uCF54\uD2B8 \uCE90\uB9AD\uD130 \u2018\uC720\uC6B0\uB098\u2019\uC785\xB7\xB7\xB7\xB7\xB7\xB7.
    \uD489, \uC880 \uC6C3\uACBC\uB2E4. \uADF8\uC9C0? \xB7\xB7\xB7\xB7\xB7\uBB34\uC2A8
    \uB18D\uB2F4\uC774\uB0D0\uAD6C? \uC606 \uAC00\uAC8C \uC120\uBC30 \uD749\uB0B4\u266A "
  - "\uD788\uC774\uB77C\uAE30 \uC5ED\uD560\uC744 \uB9E1\uC558\uB358 \uD0C0\uCE74\uD558\uC2DC
    \uC720\uC6B0\uB098\uC57C. \uC74C? \uB204\uAD6C\uB0D0\uACE0\xB7\xB7\xB7\xB7\xB7\xB7?
    \uBAA8\uB974\uACA0\uB2E4\uBA74 \uC5B8\uC81C\uB098 \uC8FC\uC778\uACF5\uC744 \uC9C0\uCF1C\uBCF4\uACE0
    \uC788\uB294  \uC218\uD638\uC2E0 \uC815\uB3C4\uB85C \uC0DD\uAC01\uD574\uC918~."
  - "\uC124\uC815\uCC3D\uC744 \uC2AC\uCA4D \uC5F4\uC5B4\uBCF4\uB2C8 \uBCF4\uC774\uB294
    \uD55C \uBA85\uC758 \uBBF8\uB140. \uD558\uB298\uD558\uB298\uD55C \uC637\uC744
    \uB450\uB974\uACE0, \uC591\uAD11\uC774 \uADF8 \uC0C8\uD558\uC580 \uBA38\uB9AC\uCE74\uB77D\uC744
    \uBE44\uCD94\uC5C8\uC2B5\uB2C8\uB2E4. \uAE38\uC744 \uC9C0\uB098\uB2E4\uAC00 \uBAA8\uB450
    \uB3CC\uC544\uBCFC\uB9CC\uD55C \uBBF8\uBAA8\uB97C \uACB8\uBE44\uD55C \uADF8\uB140\uB294
    \uB204\uAD6C\uC77C\uAE4C\uC694?\r\n\uB124, \uC800\uB78D\uB2C8\uB2E4!\r"
  - "\uC88B\uC740 \uC544\uCE68, \uC810\uC2EC, \uC800\uB141, \uBC24\uC774\uC57C! \uB124\uAC00
    \uC788\uB294 \uACF3\uC774 \uB0AE\uACFC \uBC24\uC758 \uBCC0\uD654\uAC00 \uC788\uB4E0
    \uC5C6\uB4E0, \uB098\uB294 \uC5EC\uAE30\uC11C \uAE30\uB2E4\uB9AC\uACE0 \uC788\uC5B4!"
  - "\uC124\uC815 \uD654\uBA74\uC5D0 \uC5B4\uC11C \uC640~\u266A \uB098\uB791 \uC7A1\uB2F4\uC774\uB098
    \uD560\uB798? \uADF8\uAC8C \uC544\uB2C8\uBA74\xB7\xB7\xB7\xB7\xB7 \uB098\uB97C
    \uACF5\uB7B5\uD558\uACE0 \uC2F6\uB2E4\uAC70\uB098?\r\n"
  - "\uC5EC\uAE30 \uC788\uB294 \uAE00\uC5D0 \uC2E0\uACBD\uC4F0\uC9C0 \uB9C8\uC138\uC694.
    \uB9CC\uC57D \uC2E0\uACBD \uC37C\uB2E4\uBA74, \uB2F9\uC2E0\uC740 \uC18D\uC740
    \uAC70\uB78D\uB2C8\uB2E4~\u266A\xB7\xB7\xB7\xB7\xB7.\r\n\uD6C4\uD6C4, \uC774\uC804\uBD80\uD130
    \uD574\uBCF4\uACE0 \uC2F6\uC5C8\uB358 \uB18D\uB2F4\uC774\uC57C~. \uC5B4\uC11C\uC640.
    \uD544\uC694\uD55C\uAC70\uB77C\uB3C4 \uC788\uC5B4?\r"
  - "\uC704\uC758 \uB450 \uC2AC\uB77C\uC774\uB4DC\uB97C \uC6D0\uD558\uB294 \uAC12\uC73C\uB85C
    \uB4DC\uB798\uADF8 \uD558\uBA74~ \uC5EC\uAE30\uC11C \uB0B4\uAC00 \uC5B4\uB290\uC815\uB3C4
    \uC18D\uB3C4\uB85C \uB098\uC624\uB294\uC9C0 \uB9D0\uD574\uC904\uAC8C. \uC124\uBA85\uC740
    \uD55C \uBC88\uB9CC \uD558\uB2C8\uAE4C \uC798 \uB4E4\uC5B4\uB450\uB77C\uACE0?"
  - "\uC880 \uB354 \uBE60\uB974\uAC8C\xB7\xB7\xB7\xB7\xB7\xB7. \uC544, \uADF8\uAC8C
    \uC544\uB2C8\uBA74 \uC880 \uB354 \uB290\uB9AC\uAC8C \uB9D0\uD574\uC92C\uC73C\uBA74
    \uD574? \uBA87 \uBC88\uC774\uB4E0 \uB9D0\uD574\uC918. \uC5EC\uAE30\uC11C \uAC19\uC774
    \uB9DE\uCDB0\uAC00\uBCF4\uC790\u266A"
  randomLines:
  - "\uBAA8\uB2C8\uD130 \uD654\uBA74\uC744 \uBCFC \uB54C\uC5D0\uB294, \uD654\uBA74\uC5D0\uC11C
    30cm \uC774\uC0C1 \uB5A8\uC5B4\uC838\uC11C, \uC8FC\uBCC0\uC744 \uBC1D\uAC8C \uD558\uACE0
    \uBD10\uC57C\uD574? \uC790, \uC57D\uC18D!"
  - "\uBBF8\uC548! \uC774\uB7F0 \uC800\uB7F0 \uC774\uC720\uB85C \uC5EC\uAE30\uC5D0\uC11C\uB294
    \uD45C\uC815\uC744 \uBABB \uBC14\uAFD4! \uADF8\uB7F4\uAC8C, \uC544\uB974\uBC14\uC774\uD2B8
    \uACC4\uC57D \uC0AC\uD56D\uC5D0 \uADF8\uB807\uAC8C \uC801\uD600\uC788\uB294\uAC78~"
  - "\uB0B4\uAC00 \uB9D0\uC774 \uB108\uBB34 \uB9CE\uB2E4\uACE0\xB7\xB7\xB7\xB7\xB7\xB7?
    \uD558\uC9C0\uB9CC, \uADF8\uB9CC\uD07C \uB108\uB791 \uD558\uACE0 \uC2F6\uC740
    \uC598\uAE30\uAC00 \uB9CE\uC774 \uC313\uC5EC \uC788\uB294\uAC78!"
  - "\uB2E4\uB4E4 \uC57C\uC2A4\uB2E4\uCC98\uB7FC \uC870\uC6A9\uD558\uACE0 \uC138\uB828\uB41C
    \uC5EC\uC790\uC560\uB4E4\uC774 \uCDE8\uD5A5\uC778\uAC78\uAE4C\xB7\xB7\xB7\xB7\xB7\xB7
    \uB108\uB294 \uC5B4\uB5BB\uAC8C \uC0DD\uAC01\uD574?"
  - "\uC774 \uC815\uB3C4 \uAC12\uC774\uBA74\xB7\xB7\xB7\xB7\xB7\xB7 \uC774\uB807\uAC8C
    \uB9D0\uD558\uBA74 \uB418\uACA0\uB124! \uC5B4\uB54C? \uC6D0\uD558\uB294 \uB290\uB08C\uC73C\uB85C
    \uB098\uC654\uC5B4?"
  - "\uB098\uB294 \uAD70\uC778\uB3C4 \uD588\uC5C8\uC73C\uB2C8\uAE4C \uC5EC\uBB34\uC2E0\uC774\uB77C\uACE0
    \uD560 \uC218 \uC788\uACE0. \uC554\uD638\uD559\uC5D0 \uB300\uD574\uC11C \uB2E4\uB8E8\uB294
    \uC0AC\uB78C\uC774\uB2C8\uAE4C \uBB38\uC2E0\uC774\uB77C\uACE0\uB3C4 \uD560 \uC218
    \uC788\uC5B4. \uB458\uC744 \uD569\uCCD0\uC11C \uC5EC\uC2E0!\xB7\xB7\xB7\uC774\uB77C\uACE0
    \uD558\uB294\uAC74 \uC5B4\uB54C?"
  - "\uBE44 \uC624\uB294 \uB0A0\uC740 \uC88B\uC544\uD574? \uB098\uB294 \uBE44\uC624\uB294
    \uB0A0\uC774 \uC6B0\uC0B0\uC744 \uC4F0\uACE0 \uB098\uAC00 \uBCFC \uB9CC\uD07C
    \uC88B\uC544\uD558\uB294\uB370. \uB10C \uC5B4\uB54C?"
  - "\uC2A4\uD0ED\uB864\uB9CC\uD07C\uC740 \uC548\uB418\uB354\uB77C\uB3C4, \uC774\uBC88\uC5D0\uB294
    \uC4F8 \uC218 \uC788\uB294 \uB9CC\uD07C\uC758 \uAE38\uC774\uB85C \uC791\uC131\uD574\uBCFC\uAC8C.
    \uC5B4\uB5A4 \uC774\uC57C\uAE30\uAC00 \uC88B\uC73C\uB824\uB098\xB7\xB7\xB7. \uC544!
    \uC0AC\uC2E4\uC740 \uD788\uC774\uB77C\uAE30 \uBC30\uC5ED\uC758 \uC5EC\uC790\uC560
    \uB9D0\uC774\uC57C\xB7\xB7\xB7. \uAE30\uD68D \uCD08\uCC3D\uAE30\uC5D0\uB294 \uD751\uBC1C\uC5D0
    \uB208\uC774 \uAC00\uB824\uC9C0\uB294 \uC55E\uBA38\uB9AC\uB97C \uD55C \uB514\uC790\uC778\uC774\uC5C8\uB2E4?
    \uD6C4\uD6D7, \uBBFF\uACA8\uC838?"
  - "\uC5EC\uAE30\uC11C\uB9CC\uC758 \uC774\uC57C\uAE30! \uC0AC\uD1A0\uBBF8\uB294
    \uC2A4\uD2B8\uB808\uC2A4\uB97C \uBC1B\uC73C\uBA74 \uC6D0\uB450\uB97C \uC539\uC5B4\uBA39\uB294
    \uBC84\uB987\uC774 \uC788\uC5B4. \uB9CC\uC57D \uAC54 \uC190\uC5D0 \uC6D0\uB450\uAC00
    \uD55C \uC6C0\uD07C \uC788\uB2E4\uBA74\xB7\xB7\xB7 \u2018\uC0AC\uB791\uC758 \uC735\uB2E8\uD3ED\uACA9
    \uC791\uC804\u2019\uC73C\uB85C \uD63C\uB0B4\uC8FC\uB294\uAC74 \uC5B4\uB54C? \uC608\uC804\uBD80\uD130
    \uC801\uADF9\uC801\uC778 \uAC70\uC5D0 \uC57D\uD558\uAC70\uB4E0~\u266A"
  - "\uC5EC\uAE30\uC11C\uB9CC\uC758 \uC774\uC57C\uAE30! \uCE74\uD398 \uC774\uB984\uC778
    \uD30C\uB974\uB378\uB85C(fardello)\uB294 \uC774\uD0C8\uB9AC\uC544\uC5B4\uB85C
    \u2018\uC9D0\u2019, \u2018\uAFB8\uB7EC\uBBF8\u2019\uB77C\uB294 \uB73B\uC774\uC9C0\uB9CC.\r\n\u2018\uCC45\uC784\u2019\uC774\uB77C\uB294
    \uB73B\uB3C4 \uC788\uC5B4.\r\n\xB7\xB7\xB7\uBC14\uBCF4\xB7\xB7\xB7\xB7\xB7\xB7.\r"
  - "\uC0AC\uC2E4\uC740 \uB9D0\uC774\uC57C, \uC124\uC815\uCC3D\uC744 \uC5F4\uC790\uB9C8\uC790
    \uB108\uD55C\uD14C \uD558\uB294 \uC778\uC0AC\uB9D0\uC740 \uBB34\uB824 11\uAC00\uC9C0\uC57C.
    \uC54C\uACE0 \uC788\uC5C8\uC73C\uB824\uB098?"
  - "\uB450 \uC0AC\uB78C\uC758 \uC8C4\uC218\uAC00 \uAC19\uC740 \uCC3D\uC0B4 \uB108\uBA38\uB85C
    \uCC3D\uBC16\uC744 \uB0B4\uB2E4\uBCF4\uC558\uB2E4. \uD55C \uC8C4\uC218\uB294
    \uC9C4\uD759\uD0D5\uC744 \uBCF4\uC558\uB2E4. \uB2E4\uB978 \uD55C \uC8C4\uC218\uB294
    \uBCC4\uC744 \uBCF4\uC558\uB2E4\xB7\xB7\xB7\xB7\xB7. \uB098? \uB108\uB97C \uBCF4\uACE0
    \uC788\uB294 \uC911\uC774\uC57C~\u266A"
  - "\uC720\uC6B0\uB098 \uC5EC\uAE30\uC5D0  \uC788\uC5B4! \uC774 \uC815\uB3C4 \uBAA9\uC18C\uB9AC\uB294
    \uC5B4\uB54C? \uC798 \uB4E4\uB824? \xB7\xB7\xB7\xB7\xB7\xB7\uC774\uBD10, \uB108
    \uC9C0\uAE08 \uC720\uC6B0\uB098 \uB180\uB9AC\uB294\uAC70\uC9C0?!\r\n\xB7\xB7\xB7\xB7\xB7\xB7\uBAA9\uC18C\uB9AC\uB3C4
    \uC548\uB098\uC624\uB294\uB370 \uBB50\uD558\uB0D0\uACE0? \uBE44\uC0C1\uC2DD\uB7C9
    \uB180\uC774.\r\n"
  hiddenLines:
  - "\uB69C- \uBE60\uB77C\uBC14\uB77C \uBE60\uB9AC\uBE60\uBE60\u266A  \uD754\uB4E4\uB9AC\uB294
    \uD770 \uCC9C, \uB450 \uAD6C\uBA4D\uC774~\r\n\uC81C \uBAA8\uC2B5\uC774\uC8E0\u266A 
    \uC870\uC6A9\uD55C \uC2A4\uD15D, \uC74C\uC545\uC744 \uD2C0\uACE0~ \uBA38\uB9AC\uB97C
    \uD718\uB0A0\uB9AC\uBA70\u266A\r\n\uCE68\uB300 \uC704\uC5D0\uC11C \uCDA4\uCD94\uBA70
    \uC7A0\uB4E0 \uC5BC\uAD74\uC758~ \uB2F9\uC2E0\uC744 \uC0B4\uC9DD \uC548\uC544\uC694\u266A\r"
  - "\uB9CC\uB0A0 \uC218 \uC5C6\uC5B4\u266A \uB9CC\uB098\uACE0 \uC2F6\uC740\xB7\xB7\xB7\xB7\xB7\xB7\r\n\uC774
    \uACE1\uC774 \uC6D0\uB798 \uC774\uB807\uAC8C \uC2AC\uD508 \uACE1\uC774\uC5C8\uB098?
    \uAD00\uC810\uC774 \uB2EC\uB77C\uC9C0\uB2C8  \uB290\uB08C\uB3C4 \uB2EC\uB77C\uC838\uBC84\uB838\uB124\xB7\xB7\xB7.
    \uBBF8\uC548\uD574~. \uC774\uB7F0 \uC6B0\uC911\uCDA9\uD55C \uBD84\uC704\uAE30\uB97C
    \uC6D0\uD588\uB358\uAC8C \uC544\uB2C8\uC5C8\uB294\uB370. \uC790 \uC6C3\uC5B4,
