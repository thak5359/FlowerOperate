        //ItemObjectDataм—җм„ң лҚ°мқҙн„°лҘј м¶ңл Ҙ




        foreach (var obj in pool) obj.SetActive(false);




    }


    private List<Vector3> GetAreaList(int itemId, int level)
    {



        return level switch
        {
            1 => AreaC1,
            2 => AreaC2,
            3 => AreaC3,
            4 => AreaC4,
            5 => AreaC5,
            _ => null
        };
    }

